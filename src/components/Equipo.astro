<style>
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>

<script is:inline>

function openModal(){
const modal = document.getElementById("modalCV");
modal.classList.remove("opacity-0","pointer-events-none");
}

function closeModal(){
const modal = document.getElementById("modalCV");
modal.classList.add("opacity-0","pointer-events-none");
}

</script>

<script is:inline>
  const container = document.getElementById("equipoScroll");
  const btnLeft = document.getElementById("btnLeft");
  const btnRight = document.getElementById("btnRight");

  if (btnLeft && btnRight && container) {
    btnLeft.addEventListener("click", () => {
      container.scrollBy({ left: -300, behavior: "smooth" });
    });

    btnRight.addEventListener("click", () => {
      container.scrollBy({ left: 300, behavior: "smooth" });
    });
  }
</script>


<div 
id="modalCV"
class="fixed inset-0 bg-black/80 backdrop-blur-sm flex items-center justify-center
opacity-0 pointer-events-none transition z-50"
