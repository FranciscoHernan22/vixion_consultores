 <section  id="equipo" class="bg-[#101425] py-20">
  <div class="max-w-7xl mx-auto px-6">

    <h2 class="text-3xl font-bold text-white text-center mb-12">
      Nuestro Equipo
    </h2>

    <div class="relative">

      <!-- CONTENEDOR SCROLL -->
      <div 
        id="equipoScroll"
        class="flex gap-8 overflow-x-auto scroll-smooth no-scrollbar"
      >
        {
          Array.from({ length: 11 }).map((_, i) => (
            <div class="min-w-[260px] flex-shrink-0">
              <div class="h-[380px] rounded-2xl overflow-hidden shadow-xl">
                <img                    

                  src={`/equipo${(i % 11) + 1}.PNG`} 
                  class="w-full h-full object-cover"
                />
              </div>
              <div class="mt-4 text-center">
                <h3 class="text-white font-semibold text-lg">
                  Integrante {i + 1}
                </h3>
                <p class="text-blue-400 text-sm uppercase tracking-wider">
                  Cargo Ejecutivo
                </p>
              </div>
            </div>
          ))
        }
      </div>

      <!-- FLECHA IZQUIERDA -->
      <button 
        id="btnLeft"
        class="absolute left-0 top-1/2 -translate-y-1/2 bg-[#101425]/80 text-white p-3 rounded-full shadow-lg z-10"
      >
        ←
      </button>

      <!-- FLECHA DERECHA -->
      <button 
        id="btnRight"
        class="absolute right-0 top-1/2 -translate-y-1/2 bg-[#101425]/80 text-white p-3 rounded-full shadow-lg z-10"
      >
        →
      </button>

    </div>

  </div>
</section>

<style>
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>

<script is:inline>
  const container = document.getElementById("equipoScroll");
  const btnLeft = document.getElementById("btnLeft");
  const btnRight = document.getElementById("btnRight");

  if (btnLeft && btnRight && container) {
    btnLeft.addEventListener("click", () => {
      container.scrollBy({ left: -300, behavior: "smooth" });
    });

    btnRight.addEventListener("click", () => {
      container.scrollBy({ left: 300, behavior: "smooth" });
    });
  }
</script>