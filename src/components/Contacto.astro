<script>
document.addEventListener("DOMContentLoaded", () => {

const form = document.getElementById("contactForm");

if (!(form instanceof HTMLFormElement)) return;

const nombre = form.querySelector('[name="nombre"]') as HTMLInputElement;;
const telefono = form.querySelector('[name="telefono"]') as HTMLInputElement;;
const mensaje = form.querySelector('[name="mensaje"]') as HTMLInputElement;;

const errorNombre = document.getElementById("error-nombre") as HTMLInputElement;;
const errorTelefono = document.getElementById("error-telefono") as HTMLInputElement;;
const errorMensaje = document.getElementById("error-mensaje") as HTMLInputElement;;


// VALIDAR NOMBRE
function validarNombre(){

if(nombre.value.trim().length < 3){

errorNombre.textContent="Ingrese un nombre válido";
nombre.classList.add("border-red-500","ring-red-500");

return false;

}

errorNombre.textContent="";
nombre.classList.remove("border-red-500","ring-red-500");

return true;

}


// VALIDAR TELEFONO
function validarTelefono(){

const telefonoRegex=/^[0-9]{10,15}$/;

if(!telefonoRegex.test(telefono.value.trim())){

errorTelefono.textContent="Ingrese un teléfono válido";
telefono.classList.add("border-red-500","ring-red-500");

return false;

}

errorTelefono.textContent="";
telefono.classList.remove("border-red-500","ring-red-500");

return true;

}


// VALIDAR MENSAJE
function validarMensaje(){

if(mensaje.value.trim().length < 10){

errorMensaje.textContent="Por favor describe brevemente tu situación para poder ayudarte.";
mensaje.classList.add("border-red-500","ring-red-500");

return false;

}

errorMensaje.textContent="";
mensaje.classList.remove("border-red-500","ring-red-500");

return true;

}


// VALIDACIÓN EN TIEMPO REAL
 


// SUBMIT
form.addEventListener("submit", async (e) => {

e.preventDefault();

const valid =
validarNombre() &&
validarTelefono() &&
validarMensaje();

if(!valid) return;

const formData = new FormData(form);

const data = {
nombre:formData.get("nombre"),
empresa:formData.get("empresa"),
telefono:formData.get("telefono"),
mensaje:formData.get("mensaje")
};

try{

const res = await fetch("/api/contacto",{
method:"POST",
headers:{
"Content-Type":"application/json"
},
body:JSON.stringify(data)
});

if(res.ok){

const success=document.getElementById("successMessage");
if(success) success.classList.remove("hidden");

form.reset();

}else{

alert("Error al enviar el mensaje");

}

}catch{

alert("Error de conexión");

}

});

});
</script>